add module name "menuSlide"				classname "ModuleMenuSlide"			title "Menu"			directory "modules/initial/MenuSlide/"			file "module_menu_slide.php"		desc "Menu de selection des sujets"			container_name "MenuContainer"				container_style ""						permission "group_default_read_permission"		deco ON		deco_nbr	3	;
add module name "menuAccordion"			classname "ModuleMenuAccordion"		title "Menu"			directory "modules/initial/MenuAccordion/"		file "module_menu_accordion.php"	desc "Menu de selection des sujets"			container_name "MenuContainer"				container_style ""						permission "group_default_read_permission"		deco ON		deco_nbr	3	;
add module name "quickskin"				classname "ModuleQuickSkin"			title "Quickskin"		directory "modules/initial/QuickSkin/"			file "module_quickskin.php"			desc "Changeur de skin"						container_name "QuickskinContainer"			container_style ""						permission "connected_group_read_permission"	deco ON		deco_nbr	4	;
add module name "calendar"				classname "ModuleCalendar"			title "Calendrier"		directory "modules/initial/Calendar/"			file "module_calendar.php"			desc "Calendrier"							container_name "CalendarContainer"			container_style ""						permission "group_default_read_permission"		deco ON		deco_nbr	5	;
add module name "footer"				classname "ModuleFooter"			title "Pied de page"	directory "modules/initial/Footer/"				file "module_footer.php"			desc "Pied de page"							container_name "FooterContainer"			container_style ""						permission "group_default_read_permission"		deco OFF	deco_nbr	1	;
add module name "search"				classname "ModuleSearch"			title "rechercher"		directory "modules/initial/Search/"				file "module_search.php"			desc "Moteur de recherche"					container_name "SearchContainer"			container_style ""						permission "connected_group_read_permission"	deco ON		deco_nbr	6	;
add module name "tooltip"				classname "ModuleTooltip"			title "ToolTip"			directory "modules/initial/Tooltip/"			file "module_tooltip.php"			desc "ToolTip"								container_name "TooltipContainer"			container_style "visibility:hidden"		permission "group_default_read_permission"		deco ON		deco_nbr	20		deco_txt_default	2	container_name tooltipContainer	execution AFTER;

